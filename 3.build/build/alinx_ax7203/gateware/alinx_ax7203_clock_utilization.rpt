resize_pblock [get_pblocks {CLKAG_ub_4x_clk}] -add {CLOCKREGION_X1Y2:CLOCKREGION_X1Y2 CLOCKREGION_X1Y3:CLOCKREGION_X1Y3}
#endgroup

# Clock net "sys_clk" driven by instance "BUFG" located at site "BUFGCTRL_X0Y1"
