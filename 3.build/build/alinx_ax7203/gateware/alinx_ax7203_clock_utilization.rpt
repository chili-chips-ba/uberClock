# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y0 [get_cells BUFG_3]
set_property LOC BUFGCTRL_X0Y4 [get_cells BUFG_2]
set_property LOC BUFGCTRL_X0Y3 [get_cells BUFG_1]
set_property LOC BUFGCTRL_X0Y1 [get_cells BUFG]
set_property LOC BUFGCTRL_X0Y7 [get_cells clk200_se_BUFG_inst]
set_property LOC BUFGCTRL_X0Y6 [get_cells BUFG_7]
set_property LOC BUFGCTRL_X0Y2 [get_cells BUFG_6]
set_property LOC BUFGCTRL_X0Y16 [get_cells BUFG_5]
set_property LOC BUFGCTRL_X0Y5 [get_cells BUFG_4]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X1Y123 [get_ports clk200_n]
set_property LOC IOB_X1Y124 [get_ports clk200_p]
set_property LOC IOB_X0Y228 [get_ports eth_clocks_rx]

# Clock net "uc_clk" driven by instance "BUFG_3" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_uc_clk}
add_cells_to_pblock [get_pblocks  {CLKAG_uc_clk}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="uc_clk"}]]]
resize_pblock [get_pblocks {CLKAG_uc_clk}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X0Y3:CLOCKREGION_X0Y3 CLOCKREGION_X0Y4:CLOCKREGION_X0Y4 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2 CLOCKREGION_X1Y3:CLOCKREGION_X1Y3 CLOCKREGION_X1Y4:CLOCKREGION_X1Y4}
#endgroup

# Clock net "ub_4x_dqs_clk" driven by instance "BUFG_2" located at site "BUFGCTRL_X0Y4"
#startgroup
create_pblock {CLKAG_ub_4x_dqs_clk}
add_cells_to_pblock [get_pblocks  {CLKAG_ub_4x_dqs_clk}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="ub_4x_dqs_clk"}]]]
resize_pblock [get_pblocks {CLKAG_ub_4x_dqs_clk}] -add {CLOCKREGION_X1Y3:CLOCKREGION_X1Y3}
#endgroup

# Clock net "ub_4x_clk" driven by instance "BUFG_1" located at site "BUFGCTRL_X0Y3"
